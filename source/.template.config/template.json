{
  "$schema": "http://json.schemastore.org/template",
  "author": "Mark Downie",
  "classifications": [ "Web", "Blog", "ASP.NET" ],
  "identity": "DasBlog.Template",
  "name": "DasBlog Core Blog",
  "shortName": "dasblog",
  "description": "A template for creating a new DasBlog Core blog powered by ASP.NET Core",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory": true,
  "sources": [
    {
      "source": "template-staging/",
      "target": "./",
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/logs/**",
            "**/.vs/**",
            "**/.git/**"
          ]
        }
      ]
    }
  ],
  "symbols": {
    "blogTitle": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "My DasBlog!",
      "replaces": "My DasBlog!",
      "description": "The title of your blog"
    },
    "blogUrl": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "http://localhost:5000/",
      "replaces": "https://localhost:5001/",
      "description": "The root URL of your blog"
    },
    "adminEmail": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "myemail@myemail.com",
      "replaces": "myemail@myemail.com",
      "description": "Admin email address"
    }
  },
  "primaryOutputs": [
    { "path": "DasBlog.Web.exe" }
  ]
}
