<!DOCTYPE html>
<html lang="en">
<head>
    @* Pin this theme's color mode independent of any admin/user preference written to localStorage.
       Bootswatch Darkly is itself a dark palette, so the 'light' token is its native key
       (matches `:root, [data-bs-theme=light]` in Bootswatch v5). *@
    <script>
        localStorage.setItem('dasblog-theme', 'light');
        document.documentElement.setAttribute('data-bs-theme', 'light');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <site-head-meta />
    <site-rss-link />
    <site-atom-link />
    <twitter-card />
    <open-graph />
    <blog-posting-schema />

    @* Darkly is a Bootswatch 5.3.8 swatch (https://bootswatch.com/darkly/).
       The full Bootstrap + Darkly palette ships from ~/lib/bootswatch/5.3.8/darkly/,
       and the small DasBlog-specific overrides come from ~/Themes/darkly/custom.css
       loaded by _HtmlThemePartial. *@

    <link rel="stylesheet" href="~/lib/bootswatch/5.3.8/darkly/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/6.7.2/css/all.css" />

    <partial name="_HtmlThemePartial" />

</head>

<body>
    <nav class="navbar navbar-expand-lg bg-dark" data-bs-theme="dark">
        <div class="container-fluid">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="navbar-brand"><site-title /></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-darkly" aria-controls="navbar-darkly" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbar-darkly">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" asp-area="" asp-controller="home" asp-action="index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="category" asp-action="category" asp-route-cat="">Category</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="archive" asp-action="archive" asp-route-year="" asp-route-month="" asp-route-day="">Archive</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="feed" asp-action="rss">Subscribe</a></li>
                    <li class="nav-item" dasblog-authorized><a class="nav-link" asp-area="" asp-controller="admin" asp-action="settings">[Site Settings]</a></li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item" dasblog-unauthorized><a class="nav-link" asp-controller="account" asp-action="login">Log in</a></li>
                    <li class="nav-item" dasblog-authorized><a class="nav-link" asp-controller="account" asp-action="logout">Log out</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">

        <vc:cookie-consent />

        @RenderBody()

        <div class="text-center">
            <p class="text-muted">
                <site-page-control view-context="@ViewContext" />
            </p>
        </div>

        <footer>
            <div class="text-center">
                <p class="text-muted credit"><site-copyright /></p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/3.5.1/jquery.min.js"></script>
    <script src="~/lib/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
