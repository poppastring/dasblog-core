@using DasBlog.Web.Models.AdminViewModels
@model StaticPageEditViewModel

@{
	ViewBag.Title = $"Edit {Model.DisplayTitle}";
	Layout = "../../Themes/dasblog/_Layout.cshtml";
}

<link rel="stylesheet" href="~/lib/codemirror/5.65.16/codemirror.min.css" />
<link rel="stylesheet" href="~/lib/codemirror/5.65.16/theme/eclipse.min.css" />
<link rel="stylesheet" href="~/lib/codemirror/5.65.16/theme/material-darker.min.css" />
<style>
	.CodeMirror {
		height: auto;
		min-height: 500px;
		border: 1px solid #ced4da;
		border-radius: .375rem;
		font-family: Consolas, "Courier New", monospace;
		font-size: 0.9rem;
	}
</style>

<h1>
	@Model.DisplayTitle
	<small class="text-muted ms-2">
		Public URL: <code>@Model.PublicUrlPath</code>
	</small>
	<span id="dirty-indicator" class="badge bg-warning text-dark ms-2" style="display:none;" title="You have unsaved changes">Unsaved</span>
</h1>
<hr />

<partial name="_SuccessAlertPartial" view-data="ViewData" />
<partial name="_ErrorAlertPartial" view-data="ViewData" />

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

<div class="alert alert-info">
	Enter HTML for the body of the page. The active theme's layout (header, footer, navigation) will be
	applied automatically. A blog post that shares this slug will take precedence over the static page.
</div>

<form method="post"
	  asp-controller="staticpages" asp-action="edit"
	  asp-route-name="@Model.Name">
	@Html.AntiForgeryToken()
	<input type="hidden" asp-for="Name" />

	<div class="mb-3">
		<textarea asp-for="Content"
				  id="static-page-content"
				  class="form-control font-monospace"
				  rows="25"
				  spellcheck="false"></textarea>
	</div>

	<div class="d-flex gap-2">
		<button type="submit" id="static-page-save" class="btn btn-primary" title="Save (Ctrl+S)">Save</button>
		<a class="btn btn-secondary"
		   asp-controller="staticpages" asp-action="index">Back</a>
		@if (Model.Exists)
		{
			<a class="btn btn-outline-secondary"
			   href="@Model.PublicUrlPath" target="_blank" rel="noopener">
				<i class="fas fa-external-link-alt me-1"></i>View
			</a>
		}
	</div>
</form>

@if (Model.Backups.Count > 0)
{
	<div class="card mt-3">
		<div class="card-header d-flex align-items-center">
			<i class="fas fa-history me-2"></i>
			<strong>Previous versions</strong>
			<span class="badge bg-secondary ms-2">@Model.Backups.Count</span>
		</div>
		<ul class="list-group list-group-flush">
			@for (var i = 0; i < Model.Backups.Count; i++)
			{
				var backup = Model.Backups[i];
				var modalId = $"revertModal_{i}";
				var hiddenId = $"hiddenRevertButton_{i}";
				var localTime = backup.SavedUtc.ToLocalTime();
				<li class="list-group-item d-flex flex-wrap align-items-center justify-content-between">
					<div>
						<div>
							<strong>Saved @localTime.ToString("yyyy-MM-dd HH:mm:ss")</strong>
							<span class="text-muted ms-2" title="@backup.SavedUtc.ToString("u")">
								(UTC @backup.SavedUtc.ToString("yyyy-MM-dd HH:mm:ss"))
							</span>
						</div>
						@if (i == 0)
						{
							<small class="text-muted">Most recent backup</small>
						}
					</div>
					<form method="post"
						  asp-controller="staticpages" asp-action="revert"
						  asp-route-name="@Model.Name"
						  class="d-inline">
						@Html.AntiForgeryToken()
						<input type="hidden" name="backupId" value="@backup.Id" />
						<button type="button" class="btn btn-sm btn-outline-warning"
								data-bs-toggle="modal" data-bs-target="#@modalId">
							<i class="fas fa-undo me-1"></i>Revert to this version
						</button>
						<input type="submit" id="@hiddenId" style="display:none;" />
					</form>
				</li>

				ViewData["ModalId"] = modalId;
				ViewData["ModalTitle"] = "Revert Page";
				ViewData["ModalMessage"] = $"Revert '{Model.DisplayTitle}' to the version saved at {localTime:yyyy-MM-dd HH:mm:ss}? Any newer saved versions and unsaved changes will be discarded. This cannot be undone.";
				ViewData["ModalConfirmText"] = "Revert";
				ViewData["ModalConfirmClass"] = "btn-warning";
				ViewData["HiddenButtonId"] = hiddenId;
				<partial name="_ConfirmationModalPartial" view-data="ViewData" />
			}
		</ul>
		<div class="card-footer text-muted small">
			Up to 3 previous saves are kept. Reverting to a version discards it and any newer backups (no roll-forward).
		</div>
	</div>
}

@section Scripts {
	<script src="~/lib/codemirror/5.65.16/codemirror.min.js"></script>
	<script src="~/lib/codemirror/5.65.16/mode/xml/xml.min.js"></script>
	<script src="~/lib/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
	<script src="~/lib/codemirror/5.65.16/mode/css/css.min.js"></script>
	<script src="~/lib/codemirror/5.65.16/mode/htmlmixed/htmlmixed.min.js"></script>
	<script>
		(function () {
			var textarea = document.getElementById('static-page-content');
			if (!textarea || typeof CodeMirror === 'undefined') { return; }

			function pickTheme() {
				return document.documentElement.getAttribute('data-bs-theme') === 'dark'
					? 'material-darker'
					: 'eclipse';
			}

			var editor = CodeMirror.fromTextArea(textarea, {
				mode: 'htmlmixed',
				lineNumbers: true,
				lineWrapping: true,
				indentUnit: 4,
				tabSize: 4,
				theme: pickTheme(),
				viewportMargin: Infinity,
				extraKeys: {
					'Ctrl-S': function (cm) { triggerSave(); },
					'Cmd-S': function (cm) { triggerSave(); }
				}
			});

			var observer = new MutationObserver(function () {
				editor.setOption('theme', pickTheme());
			});
			observer.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ['data-bs-theme']
			});

			var dirty = false;
			var dirtyBadge = document.getElementById('dirty-indicator');
			editor.on('change', function () {
				if (!dirty) {
					dirty = true;
					if (dirtyBadge) { dirtyBadge.style.display = ''; }
				}
			});

			function triggerSave() {
				editor.save();
				document.getElementById('static-page-save').click();
			}

			window.addEventListener('beforeunload', function (e) {
				if (dirty) {
					e.preventDefault();
					e.returnValue = '';
				}
			});

			var form = textarea.form;
			if (form) {
				form.addEventListener('submit', function () {
					editor.save();
					dirty = false;
				});
			}
		})();
	</script>
}
