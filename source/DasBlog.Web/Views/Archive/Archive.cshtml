@using DasBlog.Core.Common
@model List<MonthViewViewModel>

@{
    var previous = (DateTime)ViewBag.PreviousMonth;
    var current = (DateTime)ViewBag.CurrentMonth;
    var next = (DateTime)ViewBag.NextMonth;
    ViewData["Title"] = Constants.ArchivePageTitle;
}

<div class="container">
    <h1>@ViewData["Title"]</h1>
    <hr />

    <nav class="d-flex justify-content-center align-items-center mb-3" aria-label="Archive month navigation">
        <div class="btn-group" role="group" aria-label="Previous, current, and next month">
            <a class="btn btn-outline-secondary"
               asp-controller="Archive" asp-action="Archive"
               asp-route-year="@previous.Year" asp-route-month="@previous.Month"
               aria-label="Previous month: @($"{previous:MMMM yyyy}")"
               title="@($"{previous:MMMM yyyy}")">
                <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </a>
            <span class="btn btn-outline-secondary disabled fw-bold" aria-current="page">
                @($"{current:MMMM yyyy}")
            </span>
            <a class="btn btn-outline-secondary"
               asp-controller="Archive" asp-action="Archive"
               asp-route-year="@next.Year" asp-route-month="@next.Month"
               aria-label="Next month: @($"{next:MMMM yyyy}")"
               title="@($"{next:MMMM yyyy}")">
                <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </a>
        </div>
    </nav>

    <div class="dbc-calendar shadow-sm p-2 rounded">
        <div class="d-flex align-items-center mb-2">
            <i class="fa fa-calendar fa-2x me-3 text-secondary" aria-hidden="true"></i>
            <span class="visually-hidden">Calendar of posts for @($"{current:MMMM yyyy}")</span>
        </div>

        <ol class="day-names list-unstyled" aria-hidden="true">
            <li class="fw-bold">Sun</li>
            <li class="fw-bold">Mon</li>
            <li class="fw-bold">Tue</li>
            <li class="fw-bold">Wed</li>
            <li class="fw-bold">Thu</li>
            <li class="fw-bold">Fri</li>
            <li class="fw-bold">Sat</li>
        </ol>

        <ol class="days list-unstyled">
            @foreach (var mvvm in Model)
            {
                @foreach (var dayentry in mvvm.MonthEntries)
                {
                    var css = current.Month == dayentry.Key.Month ? string.Empty : "outside";
                    <li class="@css">
                        <div class="date">
                            @if (dayentry.Key.Day == 1)
                            {
                                @($"{dayentry.Key:MMM d}")
                            }
                            else
                            {
                                @dayentry.Key.Day
                            }
                        </div>

                        @foreach (var entry in dayentry.Value)
                        {
                            <div>
                                <post-title-link post="@entry" css="dbc-archive-anchor event" />
                            </div>
                        }
                    </li>
                }
            }
        </ol>
    </div>
</div>

