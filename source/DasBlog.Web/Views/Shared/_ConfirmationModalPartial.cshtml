@*
    OBSOLETE: This partial is retained for backward compatibility with existing themes and forks.
    For new code, prefer the TagHelper directly:  <confirmation-modal ...attributes... />
    No removal is planned.
*@
@{
    var __modalId = ViewData["ModalId"]?.ToString() ?? "confirmModal";
    var __modalTitle = ViewData["ModalTitle"]?.ToString() ?? "Confirm Action";
    var __modalMessage = ViewData["ModalMessage"]?.ToString() ?? "Are you sure you want to proceed?";
    var __modalConfirmText = ViewData["ModalConfirmText"]?.ToString() ?? "Confirm";
    var __modalConfirmClass = ViewData["ModalConfirmClass"]?.ToString() ?? "btn-primary";
    var __hiddenButtonId = ViewData["HiddenButtonId"]?.ToString() ?? "hiddenSubmitButton";
}
<confirmation-modal modal-id="@__modalId"
                    title="@__modalTitle"
                    message="@__modalMessage"
                    confirm-text="@__modalConfirmText"
                    confirm-class="@__modalConfirmClass"
                    hidden-button-id="@__hiddenButtonId" />