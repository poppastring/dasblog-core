@*
    OBSOLETE: This partial is retained for backward compatibility with existing themes and forks.
    For new code, prefer the TagHelper directly:  <error-alert alert-id="..." message-key="..." />
    No removal is planned.
*@
@{
    var __errorAlertId = ViewData["AlertId"]?.ToString() ?? "errorAlert";
    var __errorMessageKey = ViewData["MessageKey"]?.ToString() ?? "ErrorMessage";
}
<error-alert alert-id="@__errorAlertId" message-key="@__errorMessageKey" />
