@inject DasBlog.Web.Services.IDefaultCredentialsCheck DefaultCredentialsCheck

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("admin") && DefaultCredentialsCheck.IsUsingDefaults())
{
    <div class="alert alert-danger mb-0 text-center" role="alert">
        <strong>&#9888; Security Warning:</strong>
        You are still using the default admin email and/or password.
        <a asp-controller="Author" asp-action="Index" class="alert-link">Update them now</a>
        to secure your blog.
    </div>
}
